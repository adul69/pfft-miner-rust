# Ethereum mainnet private key (with leading 0x)
PRIVATE_KEY=0x_paste_your_burner_key_here

# Ethereum RPC endpoint (publicnode works, or use Alchemy/Infura for reliability)
ETH_RPC=https://ethereum-rpc.publicnode.com

# Gas config
GAS_LIMIT=250000
GAS_PRICE_MULT=1.1
MAX_GAS_GWEI=20

# Solver config
SOLVER_THREADS=
PAUSE_BETWEEN_ROUNDS=3
